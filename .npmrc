# Accept the peer-dependency conflict between eslint@9 and the cached
# @typescript-eslint/parser@5 — see Sprint 4m commit message for the
# corporate-proxy story. CI runs `npm ci` with strict peer checking
# unless this flag relaxes it. Local dev installed with --legacy-peer-deps
# at the command line; this file makes the same compromise permanent so
# CI behaves identically to the dev box.
#
# Remove this file once the proxy clears and we can install
# @typescript-eslint/parser@8 (matches eslint@9 cleanly).
legacy-peer-deps=true
